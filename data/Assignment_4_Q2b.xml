<?xml version="1.0" encoding="UTF-8"?>
<structural_model name="Assignment_4_Q2b">
  <metadata>
    <title>Q2b - Thermal Analysis</title>
    <description>Concrete frame and steel trusses subjected to uniform and gradient thermal loads.</description>
  </metadata>

  <units length="m" force="kN" temperature="C"/>

  <materials>
    <material id="conc" name="Concrete" E="30000000" alpha="8.0e-6"/>
    <material id="steel" name="Steel" E="200000000" alpha="1.2e-5"/>
  </materials>

  <sections>
    <section id="sec_conc" name="40x80 Concrete" A="0.32" I="0.01706667" d="0.8"/>
    <section id="sec_truss" name="Pipe Truss" A="0.000091106"/>
  </sections>

  <nodes>
    <node id="1" x="0.0" y="8.0"/> <!-- A -->
    <node id="2" x="7.0" y="8.0"/> <!-- B -->
    <node id="3" x="13.0" y="8.0"/> <!-- C -->
    <node id="4" x="3.0" y="0.0"/> <!-- D -->
    <node id="5" x="10.0" y="0.0"/> <!-- E -->
  </nodes>

  <elements>
    <frame id="ABC" node_i="1" node_j="3" material="conc" section="sec_conc"/>
    <truss id="BD" node_i="2" node_j="4" material="steel" section="sec_truss"/>
    <truss id="BE" node_i="2" node_j="5" material="steel" section="sec_truss"/>
  </elements>

  <boundary_conditions>
    <support node="1" type="fixed"/>
    <support node="3" type="pin"/>
    <support node="4" type="pin"/>
    <support node="5" type="pin"/>
  </boundary_conditions>

  <load_cases>
    <load_case id="LC1" name="Thermal Loading">
      <!-- Steel trusses BD and BE: Uniform +50C -->
      <temperature_load type="uniform" element="BD" delta_T="50.0"/>
      <temperature_load type="uniform" element="BE" delta_T="50.0"/>
      
      <!-- Concrete beam ABC: Bottom +50C, Top 0C (Ambient) -->
      <temperature_load type="combined" element="ABC" T_top="0.0" T_bottom="50.0"/>
    </load_case>
  </load_cases>
</structural_model>